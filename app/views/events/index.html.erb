<section class="text-nasturtium-cream" style="background-color: #508A41;">
<div class="max-w-5xl mx-auto px-6 py-20 text-center">
  <h2 class="font-serif font-light text-4xl mb-12">Wedding Details</h2>

  <% if @events.any? %>
    <div class="grid gap-12 md:grid-cols-3">
      <% @events.each do |event| %>
        <div>
          <p class="text-xs tracking-[0.3em] uppercase text-nasturtium-olive mb-3"><%= event.name %></p>
          <p class="font-serif font-light text-2xl mb-2"><%= event.date.strftime("%B %e, %Y") %></p>
          <% if event.time.present? %>
            <p class="text-nasturtium-cream/70"><%= event.time %></p>
          <% end %>
          <% if event.location.present? %>
            <p class="text-nasturtium-cream/50 text-sm mt-1"><%= event.location %></p>
          <% end %>
          <% if event.address.present? %>
            <p class="text-nasturtium-cream/50 text-sm mt-1"><%= event.address %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center text-nasturtium-cream/70">
      <p class="text-lg">Details are coming soon. Please check back!</p>
    </div>
  <% end %>
</div>

  <%# ── FAQ ── %>
  <div class="max-w-2xl mx-auto mt-20 pb-20 px-6">
    <h2 class="font-serif font-light text-4xl mb-10 text-center">FAQ</h2>

    <div class="space-y-4">
      <details class="group border border-nasturtium-cream/20 rounded">
        <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-left font-serif text-lg text-nasturtium-cream select-none">
          Are kids invited?
          <span class="ml-4 transition-transform duration-200 group-open:rotate-45 text-nasturtium-cream/60 text-2xl leading-none">+</span>
        </summary>
        <div class="px-6 pb-5 text-nasturtium-cream/70 text-sm leading-relaxed">
          While we love your kids and want to see them soon, we've planned our wedding as an adult party and kindly ask that you do not bring kids to the wedding.
        </div>
      </details>

      <details class="group border border-nasturtium-cream/20 rounded">
        <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-left font-serif text-lg text-nasturtium-cream select-none">
          What's the dress code?
          <span class="ml-4 transition-transform duration-200 group-open:rotate-45 text-nasturtium-cream/60 text-2xl leading-none">+</span>
        </summary>
        <div class="px-6 pb-5 text-nasturtium-cream/70 text-sm leading-relaxed">
          Semi-formal garden party (summer cocktail attire). September in Colorado is warm in the afternoon &mdash; likely in the high 70s or low 80s. The venue is mostly grass and gravel, so prepare your footwear accordingly.
        </div>
      </details>
    </div>
  </div>
</div>
</section>
