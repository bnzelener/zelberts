<section class="text-nasturtium-cream" style="background-color: #508A41;">
<div class="max-w-5xl mx-auto px-6 py-20 text-center">
  <h2 class="font-serif font-light text-4xl mb-12">Wedding Details</h2>

  <% if @events.any? %>
    <div class="grid gap-12 md:grid-cols-3">
      <% @events.each do |event| %>
        <div>
          <p class="text-xs tracking-[0.3em] uppercase text-nasturtium-olive mb-3"><%= event.name %></p>
          <p class="font-serif font-light text-2xl mb-2"><%= event.date.strftime("%B %e, %Y") %></p>
          <% if event.time.present? %>
            <p class="text-nasturtium-cream/70"><%= event.time %></p>
          <% end %>
          <% if event.location.present? %>
            <p class="text-nasturtium-cream/50 text-sm mt-1"><%= event.location %></p>
          <% end %>
          <% if event.address.present? %>
            <p class="text-nasturtium-cream/50 text-sm mt-1"><%= event.address %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center text-nasturtium-cream/70">
      <p class="text-lg">Details are coming soon. Please check back!</p>
    </div>
  <% end %>
</div>
</section>
