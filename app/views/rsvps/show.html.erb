<section class="max-w-2xl mx-auto px-6 py-20 text-center">
  <h1 class="font-serif font-light text-5xl text-nasturtium-forest mb-6">Thank You</h1>
  <div class="w-12 h-px bg-nasturtium-olive mx-auto mb-8"></div>

  <% if @guest.attending? %>
    <p class="text-nasturtium-forest-light text-xl mb-4">
      We're thrilled you'll be joining us, <%= @guest.first_name %>!
    </p>
    <p class="text-nasturtium-sage">
      We'll be in touch with more details as the big day approaches.
    </p>
  <% else %>
    <p class="text-nasturtium-forest-light text-xl mb-4">
      We'll miss you, <%= @guest.first_name %>.
    </p>
    <p class="text-nasturtium-sage">
      Thank you for letting us know. We'll be thinking of you!
    </p>
  <% end %>

  <% if @guest.message.present? %>
    <div class="mt-10 p-6 bg-nasturtium-olive/5 border border-nasturtium-olive/20 rounded">
      <p class="text-xs tracking-[0.2em] uppercase text-nasturtium-olive mb-3">Your note</p>
      <p class="text-nasturtium-forest-dark italic">"<%= @guest.message %>"</p>
    </div>
  <% end %>

  <div class="mt-12">
    <%= link_to "Back to Home",
        root_path,
        class: "inline-block border border-nasturtium-forest/30 text-nasturtium-forest px-8 py-3 text-sm tracking-[0.2em] uppercase hover:bg-nasturtium-forest/5 transition-colors" %>
  </div>
</section>
